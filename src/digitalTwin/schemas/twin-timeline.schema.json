{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://interstice.dev/schemas/digital-twin/twin-timeline.schema.json",
  "title": "Interstice Twin Timeline",
  "type": "object",
  "required": [
    "schemaVersion",
    "robotId",
    "clockDomain",
    "states",
    "events",
    "metadata"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "robotId": { "type": "string", "minLength": 1 },
    "clockDomain": { "type": "string", "minLength": 1 },
    "states": {
      "type": "array",
      "items": {
        "$ref": "https://interstice.dev/schemas/digital-twin/robot-state.schema.json"
      }
    },
    "events": {
      "type": "array",
      "items": { "$ref": "#/$defs/replayEvent" }
    },
    "metadata": { "$ref": "#/$defs/jsonObject" },
    "provenance": { "$ref": "#/$defs/jsonObject" }
  },
  "additionalProperties": false,
  "$defs": {
    "replayEvent": {
      "type": "object",
      "required": [
        "schemaVersion",
        "id",
        "robotId",
        "timestamp",
        "sequence",
        "type",
        "metadata"
      ],
      "properties": {
        "schemaVersion": { "const": "1.0.0" },
        "id": { "type": "string", "minLength": 1 },
        "robotId": { "type": "string", "minLength": 1 },
        "timestamp": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "sequence": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "type": { "type": "string", "minLength": 1 },
        "label": { "type": "string" },
        "metadata": { "$ref": "#/$defs/jsonObject" }
      },
      "additionalProperties": false
    },
    "replayCursorState": {
      "type": "object",
      "required": ["schemaVersion", "robotId", "index"],
      "properties": {
        "schemaVersion": { "const": "1.0.0" },
        "robotId": { "type": "string", "minLength": 1 },
        "index": { "type": "integer", "minimum": -1 }
      },
      "additionalProperties": false
    },
    "jsonValue": {
      "anyOf": [
        { "type": "null" },
        { "type": "boolean" },
        { "type": "number" },
        { "type": "string" },
        { "type": "array", "items": { "$ref": "#/$defs/jsonValue" } },
        { "$ref": "#/$defs/jsonObject" }
      ]
    },
    "jsonObject": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/jsonValue" }
    }
  }
}
