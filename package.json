{
  "name": "interstice-telemetry",
  "version": "1.0.0-rc.1",
  "description": "Deterministic telemetry, replay, and digital-twin contracts for autonomous systems.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Interstice-Systems/interstice-telemetry.git"
  },
  "homepage": "https://github.com/Interstice-Systems/interstice-telemetry#readme",
  "bugs": {
    "url": "https://github.com/Interstice-Systems/interstice-telemetry/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./digital-twin": {
      "types": "./dist/digitalTwin/browser.d.ts",
      "import": "./dist/digitalTwin/browser.js"
    }
  },
  "files": [
    "dist",
    "fixtures",
    "docs",
    "examples",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "check": "npm test && npm run typecheck && npm run lint && npm run build && node scripts/check-api-compatibility.mjs",
    "api:check": "npm run build && node scripts/check-api-compatibility.mjs",
    "api:update": "npm run build && node scripts/check-api-compatibility.mjs --update",
    "test:packed": "npm run build && node scripts/test-packed-consumers.mjs",
    "check:release": "npm run check && npm run test:packed",
    "example": "tsx examples/basic-simulation.ts",
    "example:stream": "tsx examples/event-stream.ts",
    "example:replay": "tsx examples/replay-log.ts",
    "example:scenario": "tsx examples/scenario-profile.ts",
    "example:console": "tsx examples/console-dashboard.ts",
    "example:hardware": "tsx examples/hardware-adapters.ts",
    "example:fleet": "tsx examples/fleet-scenario.ts",
    "example:artifacts": "tsx examples/experiment-artifacts.ts",
    "example:custom-artifacts": "tsx examples/custom-mission-artifacts.ts",
    "example:custom-experiment": "tsx examples/custom-experiment-bundle.ts",
    "example:adapter-stream": "tsx examples/adapter-event-stream.ts",
    "example:clock": "tsx examples/clock-system.ts",
    "example:timeline": "tsx examples/fleet-timeline.ts",
    "example:provenance": "tsx examples/provenance/basic.ts",
    "example:provenance:replay": "tsx examples/provenance/replay.ts",
    "example:provenance:twin": "tsx examples/provenance/twin.ts",
    "example:provenance:ownership": "tsx examples/provenance/ownership.ts",
    "example:evidence:manifest": "tsx examples/evidence/manifest-basic.ts",
    "example:evidence:artifacts": "tsx examples/evidence/manifest-artifacts.ts",
    "example:evidence:lineage": "tsx examples/evidence/lineage-query.ts",
    "example:evidence:coverage": "tsx examples/evidence/provenance-coverage.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "robotics",
    "telemetry",
    "observability",
    "simulation",
    "replay",
    "digital-twin",
    "evidence",
    "provenance",
    "autonomous-systems",
    "deterministic-testing"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.30.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.2.0"
  },
  "dependencies": {
    "ajv": "^8.20.0"
  }
}
