{
  "name": "interstice-telemetry",
  "version": "1.1.0",
  "description": "Deterministic telemetry, replay, and digital-twin contracts for autonomous systems.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "check": "npm test && npm run typecheck && npm run lint && npm run build",
    "example": "tsx examples/basic-simulation.ts",
    "example:stream": "tsx examples/event-stream.ts",
    "example:replay": "tsx examples/replay-log.ts",
    "example:scenario": "tsx examples/scenario-profile.ts",
    "example:console": "tsx examples/console-dashboard.ts",
    "example:hardware": "tsx examples/hardware-adapters.ts",
    "example:fleet": "tsx examples/fleet-scenario.ts",
    "example:artifacts": "tsx examples/experiment-artifacts.ts",
    "example:adapter-stream": "tsx examples/adapter-event-stream.ts",
    "example:clock": "tsx examples/clock-system.ts",
    "example:timeline": "tsx examples/fleet-timeline.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "robotics",
    "telemetry",
    "observability",
    "simulation",
    "replay",
    "digital-twin",
    "autonomous-systems",
    "deterministic-testing"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.30.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.2.0"
  }
}
