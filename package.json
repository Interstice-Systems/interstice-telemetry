{
  "name": "interstice-telemetry",
  "version": "0.6.0",
  "description": "A deterministic robotics telemetry simulator and hardware adapter interface.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "example": "tsx examples/basic-simulation.ts",
    "example:stream": "tsx examples/event-stream.ts",
    "example:replay": "tsx examples/replay-log.ts",
    "example:scenario": "tsx examples/scenario-profile.ts",
    "example:console": "tsx examples/console-dashboard.ts",
    "example:hardware": "tsx examples/hardware-adapters.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.30.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.2.0"
  }
}
